# Production-like — copy to .env.prod (not committed)
#   copy .env.prod.example .env.prod
#
# Generate a secret:  openssl rand -hex 32
#
# Use with:
#   docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.prod.yml up --build -d

ENVIRONMENT=production

POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=mini_it_platform

NGINX_PORT=80
SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Public origins for your dashboard (comma-separated)
CORS_ORIGINS=https://your-domain.example

# Documented connection string (Compose injects the same shape for the api service)
# Host MUST be "db" — the Compose service name, not localhost.
DATABASE_URL=postgresql://postgres:REPLACE_WITH_STRONG_PASSWORD@db:5432/mini_it_platform
