# Development — copy to .env.dev (not committed)
#   copy .env.dev.example .env.dev
#
# Use with:
#   docker compose --env-file .env.dev -f docker-compose.yml -f docker-compose.dev.yml up --build

ENVIRONMENT=development

# PostgreSQL (db container + optional host access via published port)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=mini_it_platform
POSTGRES_PORT=5432

# API
NGINX_PORT=80
API_PORT=8000
SECRET_KEY=dev-only-change-me-not-for-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost

# For uvicorn on your Windows host (NOT used inside the api container).
# Inside Docker, Compose sets DATABASE_URL to host "db" automatically.
DATABASE_URL=postgresql://postgres:password@localhost:5432/mini_it_platform
