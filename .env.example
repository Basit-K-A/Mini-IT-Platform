# Quick start — copy to .env in the project root
#   copy .env.example .env
#
# Compose always loads this file for ${VAR} substitution. If you also use --env-file .env.dev,
# POSTGRES_PASSWORD must match in both files. Mismatch → API unhealthy. Fix: sync passwords or
# docker compose down -v
#
# For clearer dev/prod separation, prefer:
#   .env.dev.example  →  .env.dev   (with docker-compose.dev.yml)
#   .env.prod.example →  .env.prod  (with docker-compose.prod.yml)

ENVIRONMENT=development

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=mini_it_platform
POSTGRES_PORT=5432

NGINX_PORT=80
API_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost

# Rate limiting (SlowAPI)
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=10/minute
RATE_LIMIT_REFRESH=10/minute
RATE_LIMIT_AUDIT=30/minute

# Login lockout (in-memory; single instance)
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
LOGIN_ATTEMPT_WINDOW_MINUTES=15

# Security analysis / alerts
ALERT_FAILED_LOGIN_IP_THRESHOLD=5
ALERT_FAILED_LOGIN_WINDOW_HOURS=1
ALERT_PERMISSION_DENIED_THRESHOLD=5
ALERT_RATE_LIMIT_THRESHOLD=10
ALERT_DEDUP_MINUTES=60
RATE_LIMIT_DASHBOARD=60/minute

# Local API on Windows host (uvicorn from app/) — host is localhost
DATABASE_URL=postgresql://postgres:password@localhost:5432/mini_it_platform

# Inside Docker Compose, DATABASE_URL for the api service uses host "db" (set in docker-compose.yml)
