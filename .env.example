# Copy to .env in the project root:  copy .env.example .env
#
# Use the SAME POSTGRES_PASSWORD for Docker db + api (compose reads this file).
# If you change POSTGRES_PASSWORD after the DB volume was created, run: docker compose down -v

POSTGRES_USER=postgres
# Must match the password used when the Postgres volume was first created
POSTGRES_PASSWORD=monkeymanfix
POSTGRES_DB=mini_it_platform

SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Local API (uvicorn from app/) — host is localhost ---
DATABASE_URL=postgresql://postgres:monkeymanfix@localhost:5432/mini_it_platform

# --- Docker Compose sets DATABASE_URL to host "db" automatically for the api service ---
