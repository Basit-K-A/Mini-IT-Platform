# Nexventory frontend — copy to .env.local for Vite
#   copy .env.example .env.local
#
# No trailing slash on the API base URL.

# Option A (recommended for npm run dev / npm run preview): Vite proxies /api → :8000
VITE_API_URL=/api

# Option B: Direct API — must match CORS_ORIGINS on the API container
# VITE_API_URL=http://localhost:8000

# Option C: Via nginx on port 80 (production-like)
# VITE_API_URL=http://localhost/api

# Option C: Production
# VITE_API_URL=https://api.yourdomain.com
