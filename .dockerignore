# Git and editor
.git
.gitignore
.cursor
.vscode
*.md
!app/**/*.md

# Secrets and local env (never bake into images)
.env
.env.*
!.env.*.example

# Python virtualenv and caches
**/.venv
**/__pycache__
**/*.py[cod]
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache

# Frontend (built/served separately; not part of API image)
frontend/node_modules
frontend/dist
frontend/.env
frontend/.env.*

# Docker metadata (not needed inside build context)
docker-compose*.yml
docs/

# OS / IDE noise
.DS_Store
Thumbs.db
*.log
